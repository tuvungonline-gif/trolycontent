# API Keys pool: You can provide single keys or a list of multiple keys separating them with a comma (e.g. key1,key2,key3)
# The system will prioritize free Gemini keys first, and automatically fall back to DeepSeek keys when Gemini keys are exhausted or unavailable.

# Gemini Keys pool
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# Alternatively you can configure more keys:
# GEMINI_API_KEY_1="key1"
# GEMINI_API_KEY_2="key2"
# GEMINI_API_KEYS="key3,key4"

# DeepSeek Keys pool (for fallback when Gemini is exhausted)
# DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"
# DEEPSEEK_API_KEYS="ds_key1,ds_key2"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
